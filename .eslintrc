{
    // use npm package : yarn add eslint babel-eslint
    "root": true,
    "parserOptions": {
      "ecmaVersion": 2020,
      "sourceType": "module",
      "parser": "babel-eslint", 
      "ecmaFeatures": {
        "jsx": true,
        "modules": true
      }
    },
    "env": {
      "browser": true,
      "es6": true,
      "node": true
    },
    "extends": [
    ],
    "rules": {
        //"quotes": ["error", "double"]
        "indent": ["warn", 4]
    },
    "settings": {
        "react": {
            "fragment": "Fragment",
            "version": "detect"
        }
    }
  }